# No copie secretos reales a este archivo ni lo agregue como .env al repositorio.
DTE_DATABASE_PATH=./data/dte.sqlite3
DTE_TENANT_ID=restaurant-demo
DTE_API_KEY=reemplazar-por-token-aleatorio-de-32-o-mas-caracteres
DTE_CAF_PATH=C:/ruta/segura/caf.xml
DTE_SII_CERTIFICATE_PATH=C:/ruta/segura/certificado-publico-sii.cer
DTE_SII_CERTIFICATE_SHA256=fingerprint-sha256-esperado
DTE_PFX_PATH=C:/ruta/segura/certificado-emisor.pfx
DTE_PFX_PASSWORD=solo-en-entorno-no-en-git
DTE_ENVIO_BOLETA_XSD_PATH=C:/ruta/oficial/EnvioBOLETA_v11.xsd
DTE_RESOLUTION_DATE=2026-01-01
DTE_RESOLUTION_NUMBER=0
DTE_VERIFICATION_URL=https://boletas.example.cl
DTE_HOST=127.0.0.1
DTE_PORT=8080
